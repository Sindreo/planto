# Kopier denne filen til .env.local og fyll inn verdiene fra Supabase-prosjektet ditt.
# (Project Settings -> API i Supabase-dashbordet.)
#
# VIKTIG: Dette er KUN de offentlige frontend-nøklene. De er trygge å bruke i
# nettleseren fordi Row Level Security (RLS) beskytter dataene.
# Service-role-nøkkelen og Anthropic-nøkkelen skal ALDRI ligge her – de hører
# kun hjemme som hemmelige miljøvariabler i Edge Functions (kommer i M2).

VITE_SUPABASE_URL=https://DIN-PROSJEKT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=din-anon-public-key
